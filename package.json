{
  "name": "claude-queue",
  "version": "1.0.0",
  "description": "Cross-window job queue for Claude Code — see which sessions need attention, click to jump there",
  "main": "src/tray.js",
  "scripts": {
    "start": "node src/tray.js",
    "start:silent": "node src/tray.js --no-open",
    "dashboard": "start http://127.0.0.1:51477",
    "setup": "node setup.js",
    "remove": "node setup.js --remove",
    "autostart": "node autostart.js",
    "autostart:remove": "node autostart.js --remove"
  },
  "keywords": [
    "claude",
    "claude-code",
    "queue",
    "productivity",
    "tray"
  ],
  "license": "MIT",
  "dependencies": {
    "systray2": "^2.1.4"
  }
}
